generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  compilerBuild = "fast"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  PREFER_NOT_TO_SAY
}

enum OtpType {
  EMAIL_VERIFICATION
  RESET_PASSWORD
}

enum Role {
  USER
  SHOP_OWNER
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  UNPAID
  PAID
  PROCESSING
  DONE
  CANCELED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  E_WALLET
}

enum InboxType {
  ORDER_PLACED
  ORDER_PAID
  ORDER_PROCESSING
  ORDER_DONE
  ORDER_CANCELED
}

enum AddressLabel {
  RUMAH
  KOS
  KANTOR
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  phone    String? @unique
  gender   Gender
  role     Role    @default(USER)

  avatarUrl      String?
  avatarPublicId String?

  firstName String
  lastName  String?
  birthDate DateTime

  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)

  deletedAt DateTime?

  isBanned     Boolean   @default(false)
  bannedAt     DateTime?
  bannedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  otps      Otp[]
  addresses Address[]
  store     Store?
  cartItems CartItem[]
  orders    Order[]
  reviews   Review[]
  inboxes   Inbox[]

  @@index([email])
  @@index([role])
  @@index([phone])
}

model Address {
  id            String       @id @default(uuid())
  userId        String
  label         AddressLabel
  recipientName String?
  phone         String
  street        String
  city          String
  province      String
  postalCode    String
  isDefault     Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

model Store {
  id      String @id @default(uuid())
  ownerId String @unique

  name         String
  description  String?
  logoUrl      String?
  logoPublicId String?

  openTime  String
  closeTime String

  lastOnlineAt DateTime?
  foundedAt    DateTime  @default(now())

  rating      Decimal @default(0) @db.Decimal(3, 2)
  ratingCount Int     @default(0)

  totalSold Int @default(0)

  verificationStatus      VerificationStatus @default(PENDING)
  verificationDocUrl      String
  verificationDocPublicId String
  verifiedAt              DateTime?
  rejectedReason          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products Product[]
  orders   Order[]

  @@index([ownerId])
  @@index([verificationStatus])
}

model Product {
  id      String @id @default(uuid())
  storeId String

  name          String
  description   String?
  price         Decimal @db.Decimal(12, 2)
  stock         Int     @default(0)
  imageUrl      String?
  imagePublicId String?

  rating      Decimal @default(0) @db.Decimal(3, 2)
  ratingCount Int     @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]

  @@index([storeId])
  @@index([isActive])
}

model CartItem {
  id        String @id @default(uuid())
  userId    String
  productId String
  quantity  Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Order {
  id        String @id @default(uuid())
  userId    String
  storeId   String
  addressId String

  status        OrderStatus   @default(UNPAID)
  paymentMethod PaymentMethod

  shippingFee Decimal @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  store   Store       @relation(fields: [storeId], references: [id])
  address Address     @relation(fields: [addressId], references: [id])
  items   OrderItem[]
  reviews Review[]
  inboxes Inbox[]

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String

  productName  String
  productPrice Decimal @db.Decimal(12, 2)
  quantity     Int
  unit         String  @default("pcs")
  subtotal     Decimal @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Review {
  id        String @id @default(uuid())
  userId    String
  productId String
  orderId   String

  rating  Int
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}

model Inbox {
  id      String  @id @default(uuid())
  userId  String
  orderId String?

  type   InboxType
  title  String
  body   String
  isRead Boolean   @default(false)

  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([isRead])
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      OtpType
  isUsed    Boolean  @default(false)
  attempts  Int      @default(0)
  expiredAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([code])
}
