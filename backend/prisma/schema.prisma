// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  compilerBuild = "fast"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  PREFER_NOT_TO_SAY
}

enum OtpType {
  EMAIL_VERIFICATION
  RESET_PASSWORD
}

enum Role {
  USER
  ADMIN
  AI
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  phone    String? @unique
  gender   Gender
  role     Role    @default(USER)

  avatarUrl      String?
  avatarPublicId String?

  firstName String
  lastName  String?
  birthDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // TODO add deletedAt in this row for soft delete

  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)

  otps Otp[]

  @@index([email])
  @@index([role])
  @@index([phone])
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      OtpType
  isUsed    Boolean  @default(false)
  expiredAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId]) // TODO add 'type' in indexing // TODO add 'attempts Int @default(0)'
  @@index([code])
}
